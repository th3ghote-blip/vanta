#!/usr/bin/env bash
# Block commits that contain known secret patterns.
# Catches: Supabase PAT (sbp_), Supabase service-role (sb_secret_),
# Anthropic API/admin key (sk-ant-...), Resend (re_), GitHub PAT (ghp_),
# Railway token (rly_), long bearer JWTs (eyJ... > 200 chars).
PATTERNS='(sbp_[a-f0-9]{20,}|sb_secret_[A-Za-z0-9_-]{15,}|sk-ant-(api|admin)[0-9]{2}-[A-Za-z0-9_-]{20,}|re_[A-Za-z0-9_]{20,}|ghp_[A-Za-z0-9]{30,}|rly_[A-Za-z0-9]{20,}|eyJ[A-Za-z0-9._-]{200,})'
LEAKS=$(git diff --cached -U0 | grep -nE "^\+.*$PATTERNS" || true)
if [ -n "$LEAKS" ]; then
  echo "❌ pre-commit: suspected secret found in staged changes:"
  echo "$LEAKS" | head -5
  echo
  echo "If this is a false positive, bypass with --no-verify."
  echo "Otherwise: remove the value, rotate the credential, and recommit."
  exit 1
fi
