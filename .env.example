# Vanta client env. Copy to `.env` to use as defaults (or commit overrides
# in `.env.local`, which Expo loads after `.env`).
#
# All EXPO_PUBLIC_* vars are baked into the client bundle at build time,
# so they end up visible in the JS — only put public values here.

# Supabase project (publishable / anon key is safe in client)
EXPO_PUBLIC_SUPABASE_URL=https://auavcfwytrwurawcvrsc.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_1ItN_UGD279f_bUuWCfeoQ_zze6GC1K

# Backend API on Railway
EXPO_PUBLIC_API_URL=https://vanta-server-production.up.railway.app
EXPO_PUBLIC_WS_URL=wss://vanta-server-production.up.railway.app

# Environment marker — affects banners and copy. One of: live | demo | staging
EXPO_PUBLIC_ENV=live
